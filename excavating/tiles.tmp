class_name Tiles # TileSet est déjà utilsé...
extends Resource

var _tiles: Dictionary[Vector2i,Object]
var _bounding_box: Rect2i = Rect2i();

# Inspired by https://www.reddit.com/r/godot/comments/1esljuk/elevate_your_godot_code_with_a_set_type/

#region Trait Tiled. Thank godot for not supporting them...
func on_tile_added():
	_update_bounding_box()

func on_tile_removed():
	_update_bounding_box()

func _add_tile(element: Vector2i, data: Object):
	_tiles[element] = data
	
func _remove_tile(element: Vector2) -> Object:
	if _tiles.get(element):
		var value = _tiles.get(element)
		_tiles.erase(element)
		return value
	return null

# F, func get() already exist in the parent...
func get_tile(element: Vector2i) -> Object:
	return _tiles.get(element, null)
	
func contains_tile(element: Vector2i) -> bool:
	return _tiles.has(element)

func tiles_tile() -> Array[Vector2i]:
	return _tiles.keys().duplicate()
	
func bounding_box() -> Rect2i:
	return _bounding_box
	
func move_all_tile(delta: Vector2i):
	if delta == Vector2i.ZERO:
		return
	
	var old_tiles = _tiles.duplicate()
	_tiles.clear()
	
	for pos in old_tiles.keys():
		_tiles[pos + delta] = VALUE
	
	_bounding_box.position += delta

#region Default impl
func add_tile(element: Vector2i, data: Object) -> Tiles:
	_add_tile(element, data)
	on_tile_added()
	return self
	
func add_rect_tile(rect: Rect2i, data: Object) -> Tiles:
	for x in range(rect.position.x, rect.end.x):
		for y in range(rect.position.y, rect.end.y):
			_add_tile(Vector2i(x, y), data.duplicate())
	on_tile_added()
	return self

func add_all_tile(elements: Array[Vector2i], data: Object) -> Tiles:
	for element in elements:
		_add_tile(element, data.duplicate())
	on_tile_added()
	return self

func merge_tile(other: Tiles) -> Tiles:
	add_all_tile(other.tiles())
	return self

func remove_tile(element: Vector2i) -> bool:
	var removed = _remove(element)
	if removed:
		on_tile_removed()
	return removed

func remove_all_tile(elements: Array[Vector2i]) -> Array[Vector2i]:
	var removed = []
	for element in elements:
		if _remove(element):
			removed.append(element)
	on_tile_removed()
	return removed


func nb_tile() -> int:
	return tiles().size() # Not opti because we don't need cloning the tiles

func clear_tile():
	for t in tiles():
		self._remove(t)
	on_tile_removed()

func is_tile_empty():
	return nb_tile() <= 0
#endregion
#endregion


func _update_bounding_box() -> void:
	if _tiles.is_empty():
		_bounding_box = Rect2i()
		return
	
	var min_x: int = 0
	var min_y: int = 0
	var max_x: int = 0
	var max_y: int = 0
	var first: bool = true
	
	for pos in _tiles.keys():
		if first:
			min_x = pos.x
			min_y = pos.y
			max_x = pos.x
			max_y = pos.y
			first = false
		else:
			min_x = min(min_x, pos.x)
			min_y = min(min_y, pos.y)
			max_x = max(max_x, pos.x)
			max_y = max(max_y, pos.y)
	
	_bounding_box = Rect2i(Vector2i(min_x, min_y), Vector2i(max_x - min_x + 1, max_y - min_y + 1))
	


	
func _init():
	_tiles = {}
